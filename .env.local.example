# ── MongoDB ──────────────────────────────────────────
# Get a free cluster at https://www.mongodb.com/atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/queensterDB?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────
# Any long random string — generate one with: openssl rand -hex 32
JWT_SECRET=your_super_secret_jwt_key_here

# ── API (optional — defaults are already hardcoded) ───
NEXT_PUBLIC_API_HOST=https://r1.edkt.net
